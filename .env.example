# =============================================================================
# Binny Inventory Management - Environment Variables
# =============================================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Database ---
# PostgreSQL password for the binny_admin user
DB_PASSWORD=binny_secure_2026

# Full database connection URL (used by backend service)
# In Docker, the hostname is 'postgres' (the service name).
# For local dev outside Docker, use 'localhost'.
DATABASE_URL=postgresql://binny_admin:binny_secure_2026@postgres:5432/binny_inventory

# --- Authentication ---
# Secret key for signing JWT access tokens (change in production!)
JWT_SECRET=binny_jwt_secret_change_in_production

# Secret key for signing JWT refresh tokens (change in production!)
JWT_REFRESH_SECRET=binny_refresh_secret_change_in_production

# Access token expiry (e.g., 15m, 1h, 1d)
JWT_ACCESS_EXPIRY=15m

# Refresh token expiry (e.g., 7d, 30d)
JWT_REFRESH_EXPIRY=7d

# --- Backend ---
# Node environment: development | production | test
NODE_ENV=development

# Port the backend API listens on
PORT=3001

# Allowed CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
# Public API base URL (accessible from the browser)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
