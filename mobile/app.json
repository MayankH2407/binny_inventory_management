{
  "expo": {
    "name": "Binny Inventory",
    "slug": "binny-inventory",
    "version": "1.0.0",
    "scheme": "binny",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D2A6E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.basiq360.binnyinventory"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#2D2A6E"
      },
      "package": "com.basiq360.binnyinventory",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Binny Inventory to use the camera for QR scanning"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "28e61b0e-eaa0-4dfd-aed7-695e5c6c3b10"
      }
    },
    "owner": "kanikabehl"
  }
}
